<div class="w-full max-w-sm p-8 space-y-3 rounded-xl bg-white shadow-lg">
  <h1 class="text-2xl font-bold text-center text-gray-900">Admin Login</h1>
  
  <%= form_for(resource, as: resource_name, url: session_path(resource_name)) do |f| %>
    <div class="space-y-6">
      <div class="space-y-1">
        <%= f.label :email, class: "block text-sm" %>
        <%= f.email_field :email, autofocus: true, autocomplete: "email", class: "w-full px-4 py-2 border rounded-md focus:outline-none focus:ring-2 focus:ring-indigo-500" %>
      </div>
      <div class="space-y-1">
        <%= f.label :password, class: "block text-sm" %>
        <%= f.password_field :password, autocomplete: "current-password", class: "w-full px-4 py-2 border rounded-md focus:outline-none focus:ring-2 focus:ring-indigo-500" %>
      </div>

      <div>
        <%= f.submit "Sign In", class: "w-full px-4 py-2 font-semibold text-white bg-indigo-600 rounded-md hover:bg-indigo-700" %>
      </div>
    </div>
  <% end %>
</div>
